<Window x:Class="EventViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Observateur d'Événements Moderne" 
        Height="700" Width="1200"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        RenderOptions.ClearTypeHint="Enabled">
    
    <Window.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Custom Menu Style for Visibility -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#CCCCCC"/>
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>

        <!-- Custom MenuItem Style -->
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#222222"/>
            <Setter Property="Padding" Value="10,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#BBBBBB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataTemplate for Event Items -->
        <DataTemplate x:Key="EventItemTemplate">
            <Border x:Name="ItemBorder"
                    Background="{StaticResource SurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16,12"
                    Margin="0,4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Cursor" Value="Hand"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3A3D"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="8" ShadowDepth="2" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Priority Icon with glow effect -->
                    <Grid Grid.Column="0" Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Ellipse Width="26" Height="26"
                                 Fill="{Binding LevelColor}"
                                 Opacity="0.18"/>
                        <Ellipse Width="18" Height="18"
                                 Fill="{Binding LevelColor}"
                                 Stroke="{StaticResource BorderBrush}"
                                 StrokeThickness="0.6"/>
                        <TextBlock Text="{Binding LevelGlyph}"
                                   Foreground="White"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"/>
                    </Grid>
                    
                    <!-- Date/Time -->
                    <TextBlock Grid.Column="1" Grid.Row="0"
                               Text="{Binding TimeCreated}" 
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Margin="5,0,0,0"/>
                    
                    <!-- Level and Tag -->
                    <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                        <Border Background="{Binding LevelColor}"
                                Opacity="0.15"
                                CornerRadius="4"
                                Padding="8,4"
                                Margin="0,0,8,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Level}" 
                                       Foreground="{Binding LevelColor}"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                        </Border>
                        
                        <!-- Tag (si présent) -->
                        <Border Background="{Binding TagColor}"
                                Visibility="{Binding HasTag, Converter={StaticResource BoolToVisibilityConverter}}"
                                Opacity="0.2"
                                CornerRadius="4"
                                Padding="8,4"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding TagDisplay}" 
                                       Foreground="{Binding TagColor}"
                                       FontWeight="Bold"
                                       FontSize="11"/>
                        </Border>
                    </StackPanel>
                    
                    <!-- Message -->
                    <StackPanel Grid.Column="3" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🆕 " 
                                   FontSize="14"
                                   Foreground="#4CAF50"
                                   VerticalAlignment="Center"
                                   Margin="10,0,5,0"
                                   Visibility="{Binding IsNew, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding Message}" 
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="{Binding ItemFontWeight}"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   LineHeight="18"
                                   Margin="0,0,0,0"/>
                    </StackPanel>
                    
                    <!-- Explanation (New) -->
                    <TextBlock Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="3"
                               Text="{Binding ExplanationShort}" 
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="12"
                               FontStyle="Italic"
                               Opacity="0.9"
                               Margin="5,5,0,0"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            
            <!-- Fichier Menu -->
            <MenuItem Header="📁 _Fichier" Foreground="#856404" FontWeight="SemiBold">
                <MenuItem Header="💾 _Exporter CSV" Click="MenuItem_ExportCSV_Click" Foreground="#222222"/>
                <MenuItem Header="🧾 _Exporter Rapport JSON" Click="MenuItem_ExportJson_Click" Foreground="#222222"/>
                <MenuItem Header="📂 _Ouvrir dossier export" Click="MenuItem_OpenExportFolder_Click" Foreground="#222222"/>
                <Separator Background="#AAAAAA"/>
                <MenuItem Header="🚪 _Quitter" Click="MenuItem_Quit_Click" Foreground="#721c24" FontWeight="Bold"/>
            </MenuItem>
            
            <!-- Outils Menu -->
            <MenuItem Header="🔧 _Outils" Foreground="#004085" FontWeight="SemiBold">
                <MenuItem Header="🤖 _Analyse IA complète" Click="MenuItem_AIAnalysis_Click" Foreground="#222222"/>
                <MenuItem Header="📊 _Voir Statistiques" Click="MenuItem_ViewStats_Click" Foreground="#222222"/>
                <MenuItem Header="📈 _Voir Timeline Incidents (24h)" Click="MenuItem_ViewTimeline_Click" Foreground="#222222"/>
                <MenuItem Header="🧠 _Voir Insights de Sévérité" Click="MenuItem_ViewInsights_Click" Foreground="#222222"/>
                <Separator Background="#AAAAAA"/>
                <MenuItem Header="📷 _Créer Snapshot" Click="CreateSnapshotButton_Click" Foreground="#222222"/>
                <MenuItem Header="🔍 _Comparer avec Snapshot" Click="CompareButton_Click" Foreground="#222222"/>
                <Separator Background="#AAAAAA"/>
                <MenuItem Header="📡 _Basculer télémétrie (opt-in)" Click="MenuItem_ToggleTelemetry_Click" Foreground="#222222"/>
                <MenuItem Header="🧪 _Basculer IA bêta" Click="MenuItem_ToggleAiBeta_Click" Foreground="#222222"/>
                <Separator Background="#AAAAAA"/>
                <MenuItem x:Name="AutoRefreshMenuItem" Header="⏸️ Actualisation Auto: OFF" Click="ToggleAutoRefreshMenuItem_Click" Foreground="#856404" FontWeight="Bold"/>
            </MenuItem>
            
            <!-- Maintenance Menu -->
            <MenuItem x:Name="MaintenanceMenu" Header="⚡ _Maintenance" Foreground="#155724" FontWeight="SemiBold">
                <MenuItem x:Name="MaintenanceSfcItem" Header="🛠️ Lancer SFC /scannow" Click="RepairSystemButton_Click" Foreground="#155724" FontWeight="SemiBold"/>
                <MenuItem x:Name="MaintenanceFlushDnsItem" Header="🌐 Flush DNS" Click="FlushDnsButton_Click" Foreground="#004085"/>
                <MenuItem x:Name="MaintenanceResetNetworkItem" Header="🔄 Réinitialiser Réseau" Click="ResetNetworkButton_Click" Foreground="#856404"/>
            </MenuItem>
            
            <!-- Right-aligned status items -->
            <MenuItem IsEnabled="False" HorizontalAlignment="Right">
                <MenuItem.Template>
                    <ControlTemplate>
                        <Border Background="#2D2D30" CornerRadius="4" Padding="10,4" Margin="20,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="AdminStatusIcon" Text="🔒" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock x:Name="AdminStatusText" Text="Admin requis" Foreground="#FF9800" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </MenuItem.Template>
            </MenuItem>
        </Menu>

        <!-- Main Content -->
        <Grid DockPanel.Dock="Top" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search Bar - Élégante et fine -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="SearchBox"
                             Grid.Column="0"
                             Height="28"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             Padding="10,0"
                             Background="{StaticResource BackgroundBrush}"
                             Foreground="{StaticResource TextBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="🔍 Rechercher une erreur (ex: Disk, Network, Event ID)..." 
                                                                   Foreground="{StaticResource TextBrush}"
                                                                   Opacity="0.5"
                                                                   FontSize="13"
                                                                   Margin="10,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    
                    <Button x:Name="ClearSearchButton"
                            Grid.Column="1"
                            Content="✕"
                            Width="28"
                            Height="28"
                            FontSize="14"
                            Margin="8,0,0,0"
                            Click="ClearSearchButton_Click"
                            Background="Transparent"
                            Foreground="{StaticResource TextBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand"
                            ToolTip="Effacer la recherche">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.6"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Background" Value="#F44336"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Status Bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="12,6"
                    Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock x:Name="EventCountText"
                               Grid.Column="0"
                               Text="0 erreurs trouvées"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="SemiBold"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    
                    <TextBlock x:Name="StatusText"
                               Grid.Column="1"
                               Text="Prêt"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="11"
                               Opacity="0.8"
                               Margin="20,0"
                               VerticalAlignment="Center"/>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Journal: " 
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="11"
                                   Opacity="0.7"
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0"/>
                        
                        <ComboBox x:Name="LogComboBox"
                                  Width="110"
                                  Height="24"
                                  SelectedIndex="0"
                                  Background="#CCCCCC"
                                  Foreground="#222222"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  FontSize="11">
                            <ComboBox.Resources>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="#222222"/>
                                    <Setter Property="Background" Value="#CCCCCC"/>
                                </Style>
                            </ComboBox.Resources>
                            <ComboBoxItem Content="System" Foreground="#222222"/>
                            <ComboBoxItem Content="Application" Foreground="#222222"/>
                            <ComboBoxItem Content="Security" Foreground="#222222"/>
                        </ComboBox>
                        
                        <Button Content="🔄"
                                Click="RefreshButton_Click"
                                Width="24"
                                Height="24"
                                FontSize="12"
                                Margin="10,0,0,0"
                                Background="Transparent"
                                Foreground="{StaticResource TextBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Cursor="Hand"
                                ToolTip="Actualiser la liste"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Event List -->
            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Margin="0,0,0,10">
                <ListView x:Name="EventListView"
                          Background="Transparent"
                          BorderThickness="0"
                          ItemTemplate="{StaticResource EventItemTemplate}"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Padding="10"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          MouseDoubleClick="EventListView_MouseDoubleClick"
                          SelectionChanged="EventListView_SelectionChanged"
                          ContextMenuOpening="EventListView_ContextMenuOpening">
                    <ListView.ContextMenu>
                        <ContextMenu Background="{StaticResource SurfaceBrush}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     BorderThickness="1">
                            <MenuItem Header="🤖 Analyser avec l'IA"
                                      Click="AnalyzeWithAI_Click"
                                      Foreground="{StaticResource TextBrush}"
                                      Background="{StaticResource SurfaceBrush}"/>
                            
                            <MenuItem Header="🔍 Rechercher une solution"
                                      Click="SearchSolution_Click"
                                      Foreground="{StaticResource TextBrush}"
                                      Background="{StaticResource SurfaceBrush}"/>
                            
                            <MenuItem Header="📋 Copier les détails"
                                      Click="CopyDetails_Click"
                                      Foreground="{StaticResource TextBrush}"
                                      Background="{StaticResource SurfaceBrush}"/>
                            
                            <Separator Background="{StaticResource BorderBrush}"/>

                            <MenuItem Header="👍 Recommandation utile"
                                      Click="FeedbackPositive_Click"
                                      Foreground="{StaticResource TextBrush}"
                                      Background="{StaticResource SurfaceBrush}"/>
                            <MenuItem Header="👎 Recommandation non utile"
                                      Click="FeedbackNegative_Click"
                                      Foreground="{StaticResource TextBrush}"
                                      Background="{StaticResource SurfaceBrush}"/>

                            <Separator Background="{StaticResource BorderBrush}"/>
                            
                            <MenuItem x:Name="RepairActionMenuItem"
                                      Header="🔧 Action de Réparation"
                                      Click="RepairAction_Click"
                                      Foreground="#4CAF50"
                                      FontWeight="SemiBold"
                                      Background="{StaticResource SurfaceBrush}"/>
                        </ContextMenu>
                    </ListView.ContextMenu>
                </ListView>
            </Border>

            <!-- AI Advice Panel -->
            <Border x:Name="AdvicePanel"
                    Grid.Row="3"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="#4CAF50"
                    BorderThickness="2"
                    CornerRadius="6"
                    Padding="15"
                    Margin="0,0,0,10"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🤖 Conseil IA"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="CloseAdviceButton"
                                Content="✕"
                                Click="CloseAdviceButton_Click"
                                Width="24"
                                Height="24"
                                FontSize="12"
                                Margin="10,0,0,0"
                                Background="Transparent"
                                Foreground="{StaticResource TextBrush}"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                    
                    <TextBlock x:Name="AdviceText"
                               Grid.Row="1"
                               Text="Sélectionnez un événement avec un tag pour voir le conseil."
                               FontSize="13"
                               Foreground="{StaticResource TextBrush}"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                </Grid>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="4"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock x:Name="SnapshotStatusText"
                               Grid.Column="0"
                               Text="Aucun snapshot"
                               Foreground="{StaticResource TextBrush}"
                               FontSize="11"
                               Opacity="0.7"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"/>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="💾 Application Portable" 
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Text="• Copiez-la sur une clé USB pour l'utiliser partout !"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="10"
                                   Opacity="0.8"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#4CAF50" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Optimisé &amp; Léger"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="10"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Hidden Canvas for Chart (no longer displayed but keep for compatibility) -->
            <Canvas x:Name="ChartCanvas" Visibility="Collapsed"/>
        </Grid>
    </DockPanel>
</Window>

