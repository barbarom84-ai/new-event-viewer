<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="EventViewer.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:EventViewer.WinUI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
            <converters:NullToVisibilityConverter x:Key="NullToVis" />

            <!-- Mutated at runtime by AppThemeService (keep StaticResource bindings). -->
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FF111318" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FF1A1D24" />
            <SolidColorBrush x:Key="AppSurfaceElevatedBrush" Color="#FF22262F" />
            <SolidColorBrush x:Key="AppBorderBrush" Color="#FF2E3440" />
            <SolidColorBrush x:Key="AppTextBrush" Color="#FFE8EAED" />
            <SolidColorBrush x:Key="AppMutedBrush" Color="#FF9AA0A6" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="#FF3DDC97" />
            <SolidColorBrush x:Key="AppCriticalBrush" Color="#FFFF6B6B" />
            <SolidColorBrush x:Key="AppWarningBrush" Color="#FFFFC857" />
            <SolidColorBrush x:Key="AppInfoBrush" Color="#FF6CB6FF" />
            <SolidColorBrush x:Key="AppActionBrush" Color="#FF1F6FEB" />

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style TargetType="HyperlinkButton">
                <Setter Property="Foreground" Value="{StaticResource AppAccentBrush}" />
            </Style>

            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AppActionBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AppSurfaceElevatedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style TargetType="ContentDialog">
                <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AppBorderBrush}" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
