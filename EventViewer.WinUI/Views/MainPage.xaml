<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="EventViewer.WinUI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="using:EventViewer.Core"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:EventViewer.WinUI.ViewModels"
    mc:Ignorable="d"
        Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Disabled">

    <Grid Padding="20,12,20,20" RowSpacing="12" Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Application menu bar -->
        <Border
            Grid.Row="0"
            Background="{StaticResource AppBackgroundBrush}"
            Padding="0,0,0,4">
            <MenuBar
                Background="{StaticResource AppBackgroundBrush}"
                Foreground="{StaticResource AppTextBrush}">
                <MenuBarItem Title="{x:Bind ViewModel.Strings.MenuFile, Mode=OneWay}">
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.ActionRefresh, Mode=OneWay}"
                        Command="{x:Bind ViewModel.LoadCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.ActionExportCsv, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ExportCsvCommand}" />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.ActionExportJson, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ExportJsonCommand}" />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.ExportOpenFolder, Mode=OneWay}"
                        Command="{x:Bind ViewModel.OpenExportFolderCommand}" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.SnapshotSave, Mode=OneWay}"
                        Command="{x:Bind ViewModel.CreateSnapshotCommand}" />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.SnapshotNew, Mode=OneWay}"
                        Command="{x:Bind ViewModel.CompareSnapshotCommand}"
                        IsEnabled="{x:Bind ViewModel.HasSnapshot, Mode=OneWay}" />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.SnapshotShowAll, Mode=OneWay}"
                        Command="{x:Bind ViewModel.ClearComparisonCommand}"
                        Visibility="{x:Bind ViewModel.ComparisonActive, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                </MenuBarItem>

                <MenuBarItem
                    x:Name="ToolsMenuItem"
                    Title="{x:Bind ViewModel.Strings.MenuTools, Mode=OneWay}">
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.MaintenanceFlushDns, Mode=OneWay}"
                        Click="OnFlushDnsClick"
                        IsEnabled="{x:Bind ViewModel.CanRunMaintenance, Mode=OneWay}" />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.MaintenanceSfc, Mode=OneWay}"
                        Click="OnRunSfcClick"
                        IsEnabled="{x:Bind ViewModel.CanRunMaintenance, Mode=OneWay}" />
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.MaintenanceResetNetwork, Mode=OneWay}"
                        Click="OnResetNetworkClick"
                        IsEnabled="{x:Bind ViewModel.CanRunMaintenance, Mode=OneWay}" />
                </MenuBarItem>

                <MenuBarItem Title="{x:Bind ViewModel.Strings.OptionsTitle, Mode=OneWay}">
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.MenuOptions, Mode=OneWay}"
                        Click="OnOptionsClick" />
                </MenuBarItem>

                <MenuBarItem Title="{x:Bind ViewModel.Strings.MenuHelp, Mode=OneWay}">
                    <MenuFlyoutItem
                        Text="{x:Bind ViewModel.Strings.AboutTitle, Mode=OneWay}"
                        Click="OnAboutClick" />
                </MenuBarItem>
            </MenuBar>
        </Border>

        <!-- Health banner + actions -->
        <Border
            Grid.Row="1"
            Background="{StaticResource AppSurfaceBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="18">
            <Grid ColumnSpacing="16" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource AppMutedBrush}"
                        Text="{x:Bind ViewModel.Strings.HealthBanner, Mode=OneWay}" />
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AppTextBrush}"
                        Text="{x:Bind ViewModel.HealthHeadline, Mode=OneWay}" />
                    <TextBlock
                        FontSize="14"
                        Foreground="{StaticResource AppMutedBrush}"
                        Text="{x:Bind ViewModel.HealthSubtitle, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,8,0,0">
                        <TextBlock FontSize="13" Foreground="{StaticResource AppCriticalBrush}">
                            <Run Text="{x:Bind ViewModel.ErrorCount, Mode=OneWay}" />
                            <Run Text=" " />
                            <Run Text="{x:Bind ViewModel.Strings.HealthErrors, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource AppWarningBrush}">
                            <Run Text="{x:Bind ViewModel.WarningCount, Mode=OneWay}" />
                            <Run Text=" " />
                            <Run Text="{x:Bind ViewModel.Strings.HealthWarnings, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource AppMutedBrush}"
                        Text="{x:Bind ViewModel.Strings.TimelineTitle, Mode=OneWay}" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.TimelineBuckets, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Bottom" Height="56" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="core:IncidentBucket">
                                <Border
                                    Width="10"
                                    Height="{x:Bind BarHeight}"
                                    VerticalAlignment="Bottom"
                                    CornerRadius="3"
                                    Background="{StaticResource AppAccentBrush}"
                                    ToolTipService.ToolTip="{x:Bind TotalCount}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        Grid.Column="0"
                        Width="160"
                        Header="{x:Bind ViewModel.Strings.LogHeader, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.LogOptions}"
                        SelectedItem="{x:Bind ViewModel.SelectedLog, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName" />

                    <TextBox
                        Grid.Column="1"
                        Header="{x:Bind ViewModel.Strings.SearchHeader, Mode=OneWay}"
                        PlaceholderText="{x:Bind ViewModel.Strings.SearchPlaceholder, Mode=OneWay}"
                        Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <StackPanel
                        Grid.Column="3"
                        VerticalAlignment="Bottom"
                        Spacing="2"
                        Margin="0,0,12,0">
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource AppMutedBrush}"
                            Text="{x:Bind ViewModel.SnapshotStatus, Mode=OneWay}" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource AppAccentBrush}"
                            Text="{x:Bind ViewModel.ComparisonLabel, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.ComparisonActive, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <Button
                        Grid.Column="4"
                        Content="{x:Bind ViewModel.Strings.ActionRefresh, Mode=OneWay}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.LoadCommand}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Admin info bar -->
        <InfoBar
            Grid.Row="2"
            IsOpen="{x:Bind ViewModel.NeedsAdminElevation, Mode=OneWay}"
            IsClosable="False"
            Severity="Warning"
            Title="{x:Bind ViewModel.Strings.AdminTitle, Mode=OneWay}"
            Message="{x:Bind ViewModel.Strings.AdminMessage, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsBusyMaintenance, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

        <InfoBar
            Grid.Row="2"
            IsOpen="{x:Bind ViewModel.IsBusyMaintenance, Mode=OneWay}"
            IsClosable="False"
            Severity="Informational"
            Title="{x:Bind ViewModel.Strings.MaintenanceBusyTitle, Mode=OneWay}"
            Message="{x:Bind ViewModel.MaintenanceMessage, Mode=OneWay}">
            <InfoBar.Content>
                <ProgressRing
                    Width="20"
                    Height="20"
                    IsActive="{x:Bind ViewModel.IsBusyMaintenance, Mode=OneWay}"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Left" />
            </InfoBar.Content>
        </InfoBar>

        <!-- Main split: list + detail -->
        <Grid Grid.Row="3" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="8">
                <Grid>
                    <ListView
                        x:Name="IncidentList"
                        Background="Transparent"
                        SelectionMode="Single"
                        ItemsSource="{x:Bind ViewModel.Incidents, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedIncident, Mode=TwoWay}"
                        Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:IncidentCardViewModel">
                                <Border Padding="12,10" Margin="2,4">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border
                                            Width="10"
                                            Height="10"
                                            CornerRadius="5"
                                            VerticalAlignment="Top"
                                            Margin="0,6,0,0"
                                            Background="{StaticResource AppCriticalBrush}"
                                            Visibility="{x:Bind IsCritical, Converter={StaticResource BoolToVis}}" />
                                        <Border
                                            Width="10"
                                            Height="10"
                                            CornerRadius="5"
                                            VerticalAlignment="Top"
                                            Margin="0,6,0,0"
                                            Background="{StaticResource AppWarningBrush}"
                                            Visibility="{x:Bind IsWarning, Converter={StaticResource BoolToVis}}" />

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border
                                                    Background="#334CAF50"
                                                    CornerRadius="6"
                                                    Padding="8,2"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind IsNew, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{x:Bind NewBadge}" FontSize="11" FontWeight="SemiBold" Foreground="#FF4CAF50" />
                                                </Border>
                                                <TextBlock
                                                    Text="{x:Bind Title}"
                                                    FontSize="15"
                                                    FontWeight="SemiBold"
                                                    Foreground="{StaticResource AppTextBrush}"
                                                    TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Background="#33FF6B6B" CornerRadius="6" Padding="8,2" Visibility="{x:Bind IsCritical, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{x:Bind SeverityLabel}" FontSize="11" Foreground="{StaticResource AppCriticalBrush}" />
                                                </Border>
                                                <Border Background="#33FFC857" CornerRadius="6" Padding="8,2" Visibility="{x:Bind IsWarning, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{x:Bind SeverityLabel}" FontSize="11" Foreground="{StaticResource AppWarningBrush}" />
                                                </Border>
                                                <TextBlock
                                                    Text="{x:Bind SecondaryInfo}"
                                                    FontSize="12"
                                                    Foreground="{StaticResource AppMutedBrush}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock
                                            Grid.Column="2"
                                            Text="{x:Bind RelativeTime}"
                                            FontSize="12"
                                            Foreground="{StaticResource AppMutedBrush}"
                                            VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <TextBlock
                            Text="{x:Bind ViewModel.EmptyTitle, Mode=OneWay}"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppTextBrush}"
                            HorizontalAlignment="Center" />
                        <TextBlock
                            Text="{x:Bind ViewModel.EmptyMessage, Mode=OneWay}"
                            FontSize="14"
                            Foreground="{StaticResource AppMutedBrush}"
                            TextWrapping="WrapWholeWords"
                            HorizontalAlignment="Center"
                            MaxWidth="360"
                            TextAlignment="Center" />
                    </StackPanel>

                    <ProgressRing
                        Width="48"
                        Height="48"
                        IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>

            <!-- Detail panel -->
            <Border
                Grid.Column="1"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{x:Bind ViewModel.Strings.DetailUnderstand, Mode=OneWay}" Style="{StaticResource SectionTitleStyle}" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Strings.DetailWhatToDo, Mode=OneWay}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppAccentBrush}" />
                        <Border
                            Background="#1A3DDC97"
                            BorderBrush="{StaticResource AppAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="14">
                            <StackPanel Spacing="10">
                                <TextBlock
                                    Text="{x:Bind ViewModel.Detail.Action, Mode=OneWay}"
                                    FontSize="15"
                                    Foreground="{StaticResource AppTextBrush}"
                                    TextWrapping="WrapWholeWords" />

                                <Border
                                    Background="{StaticResource AppSurfaceElevatedBrush}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Visibility="{x:Bind ViewModel.Detail.HasAutoFix, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{x:Bind ViewModel.Strings.DetailOneClick, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AppAccentBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.Detail.AutoFixTitle, Mode=OneWay}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AppTextBrush}" TextWrapping="WrapWholeWords" />
                                        <TextBlock Text="{x:Bind ViewModel.Detail.AutoFixExplanation, Mode=OneWay}" FontSize="13" Foreground="{StaticResource AppMutedBrush}" TextWrapping="WrapWholeWords" />
                                        <Button
                                            Content="{x:Bind ViewModel.Detail.AutoFixButtonLabel, Mode=OneWay}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Left"
                                            Click="OnAutoFixClick"
                                            IsEnabled="{x:Bind ViewModel.CanExecuteAutoFix, Mode=OneWay}"
                                            Visibility="{x:Bind ViewModel.Detail.CanRunAutoFix, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                        <TextBlock
                                            Text="{x:Bind ViewModel.Detail.AutoFixResult, Mode=OneWay}"
                                            FontSize="12"
                                            Foreground="{StaticResource AppAccentBrush}"
                                            TextWrapping="WrapWholeWords"
                                            Visibility="{x:Bind ViewModel.Detail.HasAutoFixResult, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>

                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Visibility="{x:Bind ViewModel.Detail.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{x:Bind ViewModel.Strings.DetailFeedbackAsk, Mode=OneWay}" FontSize="12" Foreground="{StaticResource AppMutedBrush}" VerticalAlignment="Center" />
                                    <Button Content="{x:Bind ViewModel.Strings.DetailUseful, Mode=OneWay}" Style="{StaticResource SecondaryButtonStyle}" Command="{x:Bind ViewModel.FeedbackUsefulCommand}" />
                                    <Button Content="{x:Bind ViewModel.Strings.DetailNotUseful, Mode=OneWay}" Style="{StaticResource SecondaryButtonStyle}" Command="{x:Bind ViewModel.FeedbackNotUsefulCommand}" />
                                </StackPanel>
                                <TextBlock
                                    Text="{x:Bind ViewModel.Detail.FeedbackMessage, Mode=OneWay}"
                                    FontSize="12"
                                    Foreground="{StaticResource AppAccentBrush}"
                                    Visibility="{x:Bind ViewModel.Detail.HasFeedbackMessage, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                        </Border>

                        <TextBlock
                            Text="{x:Bind ViewModel.Strings.DetailInBrief, Mode=OneWay}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppMutedBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.Detail.Headline, Mode=OneWay}"
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppTextBrush}"
                            TextWrapping="WrapWholeWords" />

                        <TextBlock
                            Text="{x:Bind ViewModel.Strings.DetailMeaning, Mode=OneWay}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AppMutedBrush}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.Detail.Meaning, Mode=OneWay}"
                            FontSize="14"
                            Foreground="{StaticResource AppTextBrush}"
                            TextWrapping="WrapWholeWords"
                            LineHeight="22" />

                        <Border
                            Background="{StaticResource AppSurfaceElevatedBrush}"
                            CornerRadius="8"
                            Padding="12"
                            Visibility="{x:Bind ViewModel.Detail.HasRelatedComponent, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="4">
                                <TextBlock
                                    Text="{x:Bind ViewModel.Strings.DetailComponent, Mode=OneWay}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AppAccentBrush}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.Detail.RelatedComponentLine, Mode=OneWay}"
                                    FontSize="14"
                                    Foreground="{StaticResource AppTextBrush}"
                                    TextWrapping="WrapWholeWords"
                                    IsTextSelectionEnabled="True" />
                            </StackPanel>
                        </Border>

                        <TextBlock
                            Text="{x:Bind ViewModel.Detail.MetaLine, Mode=OneWay}"
                            FontSize="12"
                            Foreground="{StaticResource AppMutedBrush}"
                            TextWrapping="WrapWholeWords" />

                        <Button
                            Content="{x:Bind ViewModel.Strings.DetailSummarize, Mode=OneWay}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.ExplainSelectedCommand}"
                            Visibility="{x:Bind ViewModel.Detail.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                        <Border
                            Background="{StaticResource AppSurfaceElevatedBrush}"
                            CornerRadius="8"
                            Padding="12"
                            Visibility="{x:Bind ViewModel.Detail.HasAssistantSummary, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock
                                Text="{x:Bind ViewModel.Detail.AssistantSummary, Mode=OneWay}"
                                FontSize="13"
                                Foreground="{StaticResource AppTextBrush}"
                                TextWrapping="WrapWholeWords"
                                IsTextSelectionEnabled="True" />
                        </Border>

                        <HyperlinkButton
                            Content="{x:Bind ViewModel.Strings.DetailShowTechnical, Mode=OneWay}"
                            Click="OnToggleTechnicalClick"
                            Visibility="{x:Bind ViewModel.Detail.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                        <Border
                            Background="{StaticResource AppSurfaceElevatedBrush}"
                            CornerRadius="8"
                            Padding="12"
                            Visibility="{x:Bind ViewModel.Detail.ShowTechnical, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <TextBlock
                                Text="{x:Bind ViewModel.Detail.TechnicalMessage, Mode=OneWay}"
                                FontFamily="Consolas"
                                FontSize="12"
                                Foreground="{StaticResource AppMutedBrush}"
                                TextWrapping="WrapWholeWords"
                                IsTextSelectionEnabled="True" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status / export footer -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Foreground="{StaticResource AppMutedBrush}"
                    FontSize="12"
                    VerticalAlignment="Center" />
                <TextBlock
                    Text="{x:Bind ViewModel.MaintenanceMessage, Mode=OneWay}"
                    FontSize="12"
                    Foreground="{StaticResource AppAccentBrush}"
                    VerticalAlignment="Center"
                    TextWrapping="NoWrap"
                    TextTrimming="CharacterEllipsis"
                    MaxWidth="360"
                    Visibility="{x:Bind ViewModel.HasMaintenanceMessage, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <TextBlock
                    Text="{x:Bind ViewModel.ExportMessage, Mode=OneWay}"
                    Foreground="{StaticResource AppAccentBrush}"
                    FontSize="12"
                    VerticalAlignment="Center"
                    MaxWidth="420"
                    TextTrimming="CharacterEllipsis"
                    Visibility="{x:Bind ViewModel.HasExportMessage, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                <HyperlinkButton
                    Content="{x:Bind ViewModel.Strings.ExportOpenFolder, Mode=OneWay}"
                    Command="{x:Bind ViewModel.OpenExportFolderCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

